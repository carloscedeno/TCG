{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 4,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "style": {
        "noUnusedTemplateLiteral": "warn",
        "useConst": "error",
        "useTemplate": "warn"
      },
      "complexity": {
        "noBannedTypes": "error",
        "noUselessConstructor": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "none",
      "semicolons": "always"
    }
  },
  "files": {
    "ignore": [
      "node_modules/**",
      ".venv/**",
      "__pycache__/**",
      "dist/**",
      "build/**",
      "*.py",
      "backup_before_restructure/**",
      "Documentación/**",
      "data/**",
      "logs/**",
      "*.log",
      "*.csv",
      "*.sql"
    ]
  }
}
